{
  "expo": {
    "name": "Pedagogy Center",
    "slug": "pedagogy-center-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pedagogy.center"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pedagogy.center",
      "notification": {
        "icon": "./assets/logo.png",
        "color": "#1e3a8a"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
